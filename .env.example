# Server
PORT=3000

# Optional runtime overrides. Values here are loaded on startup and take
# precedence over saved settings in data/js-deepresearch.sqlite.
LLM_PROVIDER=openai-compatible
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Search
SEARCH_ENGINE=searxng
SEARCH_BASE_URL=http://127.0.0.1:8080
SEARCH_API_KEY=

# Optional JS Eyes search provider overrides. Set SEARCH_ENGINE=js-eyes to use
# a browser-backed JS Eyes skill instead of SearXNG.
# Legacy JS_EYES_* keys are normalized into search.provider at runtime.
# JS_EYES_CLI=js-eyes
# Optional absolute CLI path when js-eyes is not on PATH (any OS).
# JS_EYES_CLI=/usr/local/bin/js-eyes
# JS_EYES_SKILL=js-zhihu-ops-skill
# Multiple skills (comma-separated; queried serially and merged):
# JS_EYES_SKILL=js-zhihu-ops-skill,js-xiaohongshu-ops-skill
# Reddit example (uses local skill-run fallback in deepresearch):
# JS_EYES_SKILL=js-reddit-ops-skill
# JS_EYES_COMMAND=search
# JS_EYES_SERVER_URL=ws://localhost:18080
# JS_EYES_MAX_PAGES=1
# JS_EYES_TIMEOUT_MS=120000
# CLI one-off override (recommended for temporary experiments):
# npm exec jdr -- research "query" --search js-eyes --search-skills js-reddit-ops-skill
# Unified facade when supported: js-eyes search "query" --skills ... --max-results 8 --json

# Research artifacts (report, findings, sources)
# WORK_DIR=work_dir
