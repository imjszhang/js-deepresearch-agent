{
  "name": "js-deepresearch-agent",
  "version": "1.0.0",
  "description": "Local single-user deep research agent built with Node.js, Express, Vite, and SQLite",
  "main": "src/server.mjs",
  "bin": {
    "js-deepresearch-agent": "src/cli.mjs",
    "jdr": "src/cli.mjs"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "server": "node src/server.mjs",
    "build": "vite build",
    "preview": "node src/server.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "lint": "eslint ."
  },
  "keywords": [
    "deep-research",
    "research-agent",
    "llm",
    "searxng",
    "ollama"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "web",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "dompurify": "^3.4.5",
    "express": "^5.2.1",
    "jsdom": "^29.1.1",
    "marked": "^18.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "supertest": "^7.2.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
